APP_NAME=clipbridge-backend
APP_ADDR=:18080
APP_READ_HEADER_TIMEOUT_SECONDS=10
APP_SHUTDOWN_TIMEOUT_SECONDS=10

DATABASE_URL=postgres://clipbridge:clipbridge@127.0.0.1:5432/clipbridge?sslmode=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME_MINUTES=120
DB_MAX_CONN_IDLE_TIME_MINUTES=30
DB_HEALTH_CHECK_SECONDS=60
DB_PING_TIMEOUT_SECONDS=3

JWT_SECRET=please-change-this-secret
ACCESS_TOKEN_TTL_MINUTES=120

CORS_ALLOW_ORIGINS=*
